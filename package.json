{
  "name": "@nikitph/flux-ui",
  "version": "0.3.0",
  "type": "module",
  "description": "A motion-first, physics-based React component library. 40 composable primitives that turn animation from a feature into a language.",
  "keywords": [
    "react",
    "motion",
    "animation",
    "physics",
    "framer-motion",
    "ui",
    "components",
    "primitives",
    "tailwindcss",
    "spring",
    "gesture",
    "scroll",
    "ai",
    "streaming",
    "accessible"
  ],
  "author": "nikitph",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikitph/flux-ui"
  },
  "homepage": "https://github.com/nikitph/flux-ui#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "node build.mjs && tsc --project tsconfig.build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "motion": ">=12.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-arm64": "^0.27.3",
    "@rollup/rollup-linux-arm64-gnu": "^4.58.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "motion": "^12.34.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
